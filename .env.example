# GitHub OAuth 配置
# 在 https://github.com/settings/applications 创建 OAuth App
# 注意：Authorization callback URL 必须填写: http://localhost:3000/api/auth/callback/github
# 说明：Docker 部署时，这些变量支持在容器运行时注入，无需在镜像构建阶段提供
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 可选：覆盖默认示例仓库来源（同样支持 Docker 运行时注入）
# NEXT_PUBLIC_GITHUB_OWNER=wu529778790
# NEXT_PUBLIC_GITHUB_REPO=navhub.shenzjd.com
# NEXT_PUBLIC_DATA_FILE_PATH=data/sites.json

# 本地开发时，确保 OAuth App 的回调 URL 包含:
# - http://localhost:3000/api/auth/callback/github (开发环境)
# - https://navhub.shenzjd.com/api/auth/callback/github (生产环境)
